# ==========================================
# Student Mental Health Tracker - Backend
# ==========================================

# MongoDB Atlas Connection String
# Replace with your actual MongoDB Atlas URI
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/mental_health_tracker?retryWrites=true&w=majority

# JWT Secret Key (change to a strong random string in production)
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# Server Port
PORT=5000

# Environment
NODE_ENV=development
